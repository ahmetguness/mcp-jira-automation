# ── Jira ──────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=KAN
JIRA_AI_BOT_DISPLAY_NAME=AI Cyber Bot
# JIRA_REPO_FIELD_ID=customfield_XXXXX  # Optional: Auto-detected if not set (looks for "Repository" or "Repo" field)
# JIRA_CREDENTIALS_FIELD_ID=customfield_XXXXX  # Optional: Auto-detected (looks for "Credentials" or "API Key" field)
# JIRA_BASE_URL_FIELD_ID=customfield_XXXXX  # Optional: Auto-detected (looks for "Base URL" or "API URL" field)
# JQL_ASSIGNED_TO_BOT=assignee = "AI Cyber Bot" AND statusCategory != Done ORDER BY created DESC

# ── Listener ──────────────────────────────────────
MODE=poll                   # poll | webhook
POLL_INTERVAL_MS=15000
# WEBHOOK_PORT=3000         # sadece MODE=webhook

# ── SCM ───────────────────────────────────────────
SCM_PROVIDER=github         # github | gitlab | bitbucket
GITHUB_TOKEN=ghp_your-github-token
# GITLAB_TOKEN=glpat-your-gitlab-token
# GITLAB_URL=https://gitlab.com
# Bitbucket: set SCM_PROVIDER=bitbucket and use Jira Repository as workspace/repo-slug.
# Bitbucket SCM operations use the Bitbucket Cloud REST API directly.
# API tokens replace app passwords for new Bitbucket integrations.
# REST API auth uses Atlassian account email + API token.
# Git clone uses x-bitbucket-api-token-auth + API token.
BITBUCKET_EMAIL=your-atlassian-email@example.com
BITBUCKET_API_TOKEN=your-bitbucket-api-token
# BITBUCKET_USERNAME=your-bitbucket-username
# BITBUCKET_WORKSPACE=your-workspace
# Deprecated: app passwords cannot be created after 2025-09-09 and stop working on 2026-06-09.
# BITBUCKET_APP_PASSWORD=your-existing-app-password

# ── AI ────────────────────────────────────────────
AI_PROVIDER=openai          # openai | anthropic | gemini | vllm | aider
# AI_MODEL=gpt-4o           # varsayılan: provider'a göre otomatik
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# GEMINI_API_KEY=your-gemini-key
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Aider (AI_PROVIDER=aider olduğunda) ──────────
# AIDER_MODEL=gpt-4o        # aider'ın kullanacağı model (gpt-4o, claude-3-5-sonnet, vb.)
# AIDER_PATH=aider           # aider binary yolu (pip install aider-chat ile kurulur)

# ── Executor ──────────────────────────────────────
# Used for both code generation and API test execution in Docker containers
EXECUTOR_BACKEND=local      # local | ssh
EXEC_POLICY=strict          # strict | permissive
DOCKER_IMAGE=auto           # auto | node:20-bookworm vb.
EXEC_TIMEOUT_MS=300000      # Timeout for test execution (5 minutes default)

# SSH Docker executor (only used when EXECUTOR_BACKEND=ssh)
# Runs git clone, patch upload, Docker test execution, and cleanup on a remote host.
# The remote user must have git and Docker access.
# For SCM_PROVIDER=github, github-mcp-server also runs on the SSH host via Docker.
# For SCM_PROVIDER=bitbucket, SCM operations use Bitbucket Cloud REST API directly.
# SSH_HOST=192.0.2.10
# SSH_PORT=22
# SSH_USER=ubuntu
# SSH_PRIVATE_KEY_PATH=C:\Users\you\.ssh\id_rsa
# SSH_REMOTE_WORKDIR=/opt/mcp-jira-automation/workspaces
# SSH_CONNECT_TIMEOUT_MS=15000
# SSH_CLEANUP_WORKSPACE=true
# SSH_REMOVE_IMAGE=false      # true deletes the used Docker image after each run; slower but cleans disk

# ── Execution Mode ────────────────────────────────
# EXECUTION_MODE controls how tests are run:
#   remote  (default) — Tests target an already-running service via API_BASE_URL.
#                        No backend startup, no dependency installation, no database services.
#                        Fast and lightweight — ideal for staging/dev environments.
#   sandbox           — Backend is cloned, built, and started inside a Docker container.
#                        Full isolation with dependency installation and database services.
#                        Use when no external environment is available.
EXECUTION_MODE=remote
# API_BASE_URL is required for remote mode. Set to the base URL of the running API.
# Can also be overridden per-task by adding "base_url: https://..." in the Jira description.
API_BASE_URL=https://staging-api.example.com

# ── MCP Atlassian ─────────────────────────────────
MCP_SSE_URL=http://127.0.0.1:9000/sse

# ── Webhook Security ─────────────────────────────
# WEBHOOK_SECRET: HMAC-SHA256 secret for verifying webhook signatures.
# Required for production when MODE=webhook. Without this, any POST to /webhook is accepted.
# WEBHOOK_SECRET=your-webhook-secret-here

# ── Container Test Environment ────────────────────
# Override default test environment variables injected into Docker containers.
# Comma-separated KEY=VALUE pairs. These override the built-in defaults.
# CONTAINER_TEST_ENV=JWT_SECRET=my-custom-secret,API_KEY=my-custom-key

# ── API Testing & Approval Workflow ───────────────
# REQUIRE_APPROVAL: Controls whether generated API tests require approval before execution
# - true:  Generated tests are posted to Jira for review. The orchestrator waits for 
#          task status transition before executing tests. Use this when you want to 
#          review test quality and prevent unnecessary test runs.
# - false: Tests are executed immediately after generation without approval gate.
#          Use this for automated CI/CD workflows or when test quality is trusted.
# Default: false
# Requirements: 12.1, 12.5
REQUIRE_APPROVAL=false

# ── Logging & State ───────────────────────────────
LOG_LEVEL=info              # debug | info | warn | error
STATE_FILE=./data/state.json
MAX_ATTEMPTS=3

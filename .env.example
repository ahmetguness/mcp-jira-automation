# ── Jira ──────────────────────────────────────────
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=KAN
JIRA_AI_BOT_DISPLAY_NAME=AI Cyber Bot
# JIRA_REPO_FIELD_ID=customfield_XXXXX
# JQL_ASSIGNED_TO_BOT=assignee = "AI Cyber Bot" AND statusCategory != Done ORDER BY created DESC

# ── Listener ──────────────────────────────────────
MODE=poll                   # poll | webhook
POLL_INTERVAL_MS=15000
# WEBHOOK_PORT=3000         # sadece MODE=webhook

# ── SCM ───────────────────────────────────────────
SCM_PROVIDER=github         # github | gitlab | bitbucket
GITHUB_TOKEN=ghp_your-github-token
# GITLAB_TOKEN=glpat-your-gitlab-token
# GITLAB_URL=https://gitlab.com
# BITBUCKET_USERNAME=your-username
# BITBUCKET_APP_PASSWORD=your-app-password
# BITBUCKET_WORKSPACE=your-workspace

# ── AI ────────────────────────────────────────────
AI_PROVIDER=openai          # openai | anthropic | gemini | vllm
# AI_MODEL=gpt-4o           # varsayılan: provider'a göre otomatik
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-key
# GEMINI_API_KEY=your-gemini-key
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Executor ──────────────────────────────────────
EXEC_POLICY=strict          # strict | permissive
DOCKER_IMAGE=node:20-bookworm
EXEC_TIMEOUT_MS=300000

# ── MCP Atlassian ─────────────────────────────────
MCP_SSE_URL=http://127.0.0.1:7000/sse

# ── PR & Onay ─────────────────────────────────────
REQUIRE_APPROVAL=false

# ── Logging & State ───────────────────────────────
LOG_LEVEL=info              # debug | info | warn | error
STATE_FILE=./data/state.json
MAX_ATTEMPTS=3
############################
# JIRA (mcp-atlassian)
############################

JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=KAN

# AI bot kullanıcı adı (Jira'da oluşturulmalı)
JIRA_AI_BOT_DISPLAY_NAME=AI Cyber Bot

# Repository custom field ID (Jira Admin > Custom Fields'den alınır)
JIRA_REPO_FIELD_ID=customfield_XXXXX

# Opsiyonel: JQL override (varsayılan: assignee = "AI Cyber Bot" AND ...)
# JQL_ASSIGNED_TO_BOT=assignee = "AI Cyber Bot" AND statusCategory != Done ORDER BY created DESC

############################
# LISTENER MODU
############################

# poll | webhook
MODE=poll

# Polling aralığı (ms) — sadece MODE=poll iken kullanılır
POLL_INTERVAL_MS=15000

# Webhook portu — sadece MODE=webhook iken kullanılır
# WEBHOOK_PORT=3000

############################
# SCM PROVIDER
############################

# github | gitlab | bitbucket
SCM_PROVIDER=github

# GitHub
GITHUB_TOKEN=ghp_your-github-token

# GitLab
# GITLAB_TOKEN=glpat-your-gitlab-token
# GITLAB_URL=https://gitlab.com

# Bitbucket
# BITBUCKET_USERNAME=your-username
# BITBUCKET_APP_PASSWORD=your-app-password
# BITBUCKET_WORKSPACE=your-workspace

############################
# AI PROVIDER
############################

# openai | anthropic | gemini | vllm
AI_PROVIDER=openai

# Opsiyonel: Model override (varsayılan: openai=gpt-4o, anthropic=claude-sonnet-4-20250514, gemini=gemini-2.0-flash)
# AI_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key

# Gemini
# GEMINI_API_KEY=your-gemini-key

# vLLM (self-hosted, OpenAI-compatible)
# ⚠️ Tool/function calling destekleyen model kullanın!
# Önerilen: Qwen2.5-72B-Instruct, Llama-3.1-70B-Instruct, Mistral-Large
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

############################
# EXECUTOR
############################

# strict: sadece whitelist komutlar | permissive: sadece blacklist engeller
EXEC_POLICY=strict

# Docker image (repo çalıştırma ortamı)
DOCKER_IMAGE=node:20-slim

# Timeout (ms)
EXEC_TIMEOUT_MS=300000

############################
# MCP ATLASSIAN
############################

# mcp-atlassian SSE endpoint (ayrı çalışıyorsa)
MCP_SSE_URL=http://127.0.0.1:9000/sse

############################
# PR & ONAY
############################

# true ise AI önce planını Jira'ya yazar, onay bekler
REQUIRE_APPROVAL=false

############################
# LOGGING & STATE
############################

LOG_LEVEL=info
STATE_FILE=./data/state.json
# MCP-ATLASSIAN CONFIGURATION EXAMPLE
# -------------------------------------
# Copy this file to mcp-atlassian.env and fill in your details.

# =============================================
# ESSENTIAL ATLASSIAN INSTANCE URLS
# =============================================
JIRA_URL=https://your-company.atlassian.net
CONFLUENCE_URL=https://your-company.atlassian.net/wiki

# =============================================
# AUTHENTICATION: API TOKEN (Recommended for Atlassian Cloud)
# =============================================
# Get API tokens from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_USERNAME=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

CONFLUENCE_USERNAME=your.email@example.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# =============================================
# OPTIONAL CONFIGURATION
# =============================================
# Transport mode for the MCP server
TRANSPORT=sse

# Port for 'sse' transport (must match MCP_SSE_URL in .env)
PORT=9000

# Host for 'sse' transport
HOST=0.0.0.0

# =============================================
# LOGGING CONFIGURATION
# =============================================
# FastMCP Log Level (controls internal MCP server logs)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: ERROR (only shows errors, suppresses verbose worker logs)
FASTMCP_LOG_LEVEL=ERROR

# MCP Verbose Mode (controls tool execution logs)
# MCP_VERY_VERBOSE=true   # DEBUG level - very verbose (only for troubleshooting)
# MCP_VERBOSE=true        # INFO level - normal usage (shows all operations)
# Leave both commented out for minimal logging (recommended for production)

# =============================================
# TOOLSET CONFIGURATION
# =============================================
# Toolset Filtering
# Options: all, default, jira, confluence, jira-admin, confluence-admin, etc.
# Set to "all" to enable all available toolsets (recommended)
TOOLSETS=all

# Read-Only Mode (disable write operations)
# READ_ONLY_MODE=false

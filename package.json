{
  "name": "mcp-jira-automation",
  "version": "1.0.0",
  "description": "AI-powered Jira automation bot — polls for tasks, reads code from SCM, analyzes with AI, tests in Docker, reports back to Jira",
  "main": "dist/index.js",
  "scripts": {
    "dev": "chcp 65001 >nul 2>&1 & tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "jira",
    "mcp",
    "ai",
    "automation",
    "devops"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.3.3",
    "@types/tar-stream": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "dockerode": "^4.0.9",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "tar-stream": "^3.1.8",
    "zod": "^4.3.6"
  }
}
